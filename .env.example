# App URLs
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000

# Must be 32+ random bytes in production
BETTER_AUTH_SECRET=replace-with-long-random-string
BETTER_AUTH_REQUIRE_EMAIL_VERIFICATION=false

# Better Auth rate limit defaults
BETTER_AUTH_RATE_LIMIT_WINDOW=60
BETTER_AUTH_RATE_LIMIT_MAX=100

# SurrealDB
SURREALDB_URL=http://127.0.0.1:8000/rpc
SURREALDB_NS=govquest
SURREALDB_DB=app
SURREALDB_USER=govquest
SURREALDB_PASS=replace-with-strong-db-password

# Better Auth Google OAuth (optional)
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me

# SMTP for auth + feedback emails
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="GovQuest <no-reply@example.com>"
FEEDBACK_ADMIN_EMAIL=admin@example.com
