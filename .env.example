# App
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-long-random-string

# SurrealDB
SURREALDB_URL=http://127.0.0.1:8000/rpc
SURREALDB_NS=govquest
SURREALDB_DB=app
SURREALDB_USER=root
SURREALDB_PASS=root

# Better Auth Google OAuth (replace with your real credentials)
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me

# SMTP for feedback email relay
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="GovQuest <no-reply@example.com>"
FEEDBACK_ADMIN_EMAIL=admin@example.com
